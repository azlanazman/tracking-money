rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Each user owns only their own subtree
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Temporary: allow authenticated reads on old flat paths for one-time migration.
    // Remove these after migration is confirmed.
    match /transactions/{doc} {
      allow read, delete: if request.auth != null;
    }
    match /settings/{doc} {
      allow read, delete: if request.auth != null;
    }
    match /budgets/{doc} {
      allow read, delete: if request.auth != null;
    }
    match /goals/{doc} {
      allow read, delete: if request.auth != null;
    }

  }
}
